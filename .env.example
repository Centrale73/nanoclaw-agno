# ── LLM Providers (at least one required) ──────────────────

# Anthropic (recommended primary)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
OPENAI_API_KEY=sk-...

# Groq (fastest inference)
GROQ_API_KEY=gsk_...

# xAI / Grok (real-time X data)
XAI_API_KEY=xai-...

# Perplexity (built-in live web search)
PERPLEXITY_API_KEY=pplx-...

# OpenRouter (universal backstop — any model)
OPENROUTER_API_KEY=sk-or-...


# ── Channels (enable as needed) ────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=...

# Discord
DISCORD_BOT_TOKEN=...

# Slack (Socket Mode)
SLACK_BOT_TOKEN=xoxb-...
SLACK_APP_TOKEN=xapp-...


# ── Config ─────────────────────────────────────────────────

TRIGGER_WORD=@Andy
MAX_CONCURRENT_AGENTS=4
ROOT_PROVIDER=claude-sonnet
